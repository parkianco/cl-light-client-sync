(defmacro with-light-client-sync-timing (&body body)
  "Executes BODY and logs the execution time specific to cl-light-client-sync."
  (let ((start (gensym))
        (end (gensym)))
    `(let ((,start (get-internal-real-time)))
       (multiple-value-prog1
           (progn ,@body)
         (let ((,end (get-internal-real-time)))
           (format t "~&[cl-light-client-sync] Execution time: ~A ms~%"
                   (/ (* (- ,end ,start) 1000.0) internal-time-units-per-second)))))))

(defun light-client-sync-batch-process (items processor-fn)
  "Applies PROCESSOR-FN to each item in ITEMS, handling errors resiliently.
Returns (values processed-results error-alist)."
  (let ((results nil)
        (errors nil))
    (dolist (item items)
      (handler-case
          (push (funcall processor-fn item) results)
        (error (e)
          (push (cons item e) errors))))
    (values (nreverse results) (nreverse errors))))

(defun light-client-sync-health-check ()
  "Performs a basic health check for the cl-light-client-sync module."
  (let ((ctx (initialize-light-client-sync)))
    (if (validate-light-client-sync ctx)
        :healthy
        :degraded)))
